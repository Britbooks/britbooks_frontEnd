# ─────────────────────────────────────────────
# BritBooks API — Environment Variables Template
# Copy to .env and fill in values. Never commit .env.
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/britbooks?retryWrites=true&w=majority

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=<minimum-32-character-random-secret>
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+44...

# Email — Nodemailer / Resend
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@britbooks.co.uk
SMTP_PASS=...
RESEND_API_KEY=re_...

# OpenAI
OPENAI_API_KEY=sk-...

# Google AI
GOOGLE_AI_API_KEY=...

# Google OAuth (if used)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# FTP
FTP_HOST=localhost
FTP_PORT=21
FTP_USER=ftpuser
FTP_PASS=...

# Monitoring / Alerts
ALERT_EMAIL=ops@britbooks.co.uk
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Nexcess / Hosting
NEXCESS_API_KEY=...
NEXCESS_API_URL=...
