{
  "expo": {
    "name": "BritBooks",
    "slug": "britbooks",
    "owner": "structurezz01",
    "scheme": "britbooks",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/43ebace8-e19a-43d4-8bb7-76c7c9834d41"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.britbooks.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "BritBooks uses your camera so you can attach photos to support messages.",
        "NSPhotoLibraryUsageDescription": "BritBooks uses your photo library so you can attach images to support messages.",
        "NSPhotoLibraryAddUsageDescription": "BritBooks saves images from your support conversations.",
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.britbooks.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0A1628",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "BritBooks uses your photo library so you can attach images to support messages.",
          "cameraPermission": "BritBooks uses your camera so you can attach photos to support messages."
        }
      ],
      "expo-splash-screen",
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "43ebace8-e19a-43d4-8bb7-76c7c9834d41"
      }
    }
  }
}
